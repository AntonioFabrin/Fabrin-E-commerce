# ── Servidor ─────────────────────────────────────────────────
PORT=3333

# ── Autenticação ──────────────────────────────────────────────
# Troque por uma string longa e aleatória em produção
JWT_SECRET=sua_chave_secreta_aqui

# ── Banco de Dados (MySQL) ────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=ecommerce

# ── Mercado Pago ──────────────────────────────────────────────
# Pegue em: https://www.mercadopago.com.br/developers/panel/credentials
# Use as credenciais de TESTE (começam com TEST- ou APP_USR- da aba de testes)
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_DE_TESTE_AQUI
MP_PUBLIC_KEY=SUA_PUBLIC_KEY_DE_TESTE_AQUI

# ── Frontend ──────────────────────────────────────────────────
# URL base do frontend (para o MP redirecionar após pagamento)
FRONTEND_URL=http://localhost:3000
